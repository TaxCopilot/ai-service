# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server API Key (Shared Secret)
# Leave empty for local dev to disable auth. Set in prod for Next.js to authenticate.
API_KEY=your-super-secret-key-123

# AWS credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-south-1

# Textract
TEXTRACT_MIN_CONFIDENCE=80.0   # drop OCR lines below this score (0-100)

# Bedrock LLM
# Swap to anthropic.claude-opus-4-6-v1 for higher quality at extra cost
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.2
bedrock-api-key-


BEDROCK_KNOWLEDGE_BASE_ID=PLACEHOLDER_KB_ID
BEDROCK_RETRIEVAL_RESULTS=5

# PostgreSQL Vector Database
# Local: postgresql://postgres:postgres@localhost:5432/postgres
# AWS RDS: postgresql://postgres:YOUR_PASSWORD@taxcopilot-db.cxxxxxxx.us-east-1.rds.amazonaws.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Server
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
