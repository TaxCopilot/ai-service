# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server API Key (Shared Secret)
# Leave empty for local dev to disable auth. Set in prod for Next.js to authenticate.        
API_KEY=your-super-secret-key-123

# AWS credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-south-1

# Textract
TEXTRACT_MIN_CONFIDENCE=50.0   # drop OCR lines below this score (0-100)

# Bedrock LLM
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.2

# PostgreSQL Vector Database
# Local: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Server
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
